{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/:path(.*)",
      "has": [{ "type": "host", "value": "utsavify.com" }],
      "destination": "https://www.utsavify.com/:path",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/product/:slug", "destination": "/api/product-page?slug=:slug" },
    { "source": "/sitemap.xml", "destination": "/api/sitemap" },
    { "source": "/merchant-feed.xml", "destination": "/api/merchant-feed" },
    { "source": "/return-policy", "destination": "/return-policy.html" },
    { "source": "/privacy-policy", "destination": "/privacy-policy.html" },
    { "source": "/terms-conditions", "destination": "/terms-conditions.html" },
    { "source": "/raksha-bandhan-2026-gift-guide", "destination": "/api/rakhi-guide" },
    { "source": "/rakhi-for-brother", "destination": "/api/category-hub?hub=brother" },
    { "source": "/rakhi-combo-family-pack", "destination": "/api/category-hub?hub=combo" },
    { "source": "/llms.txt", "destination": "/api/llms" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
